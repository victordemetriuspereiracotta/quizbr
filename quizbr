    <button class="btn pulse" id="send">Liberar meu plano &rarr;</button>
    <p class="cap-foot">${ckGreen} Sem spam. Só o seu plano e os próximos passos.</p>
  </div>`;
  const iWpp=document.getElementById('iWpp');
  iWpp.addEventListener('input',e=>{
    let v=e.target.value.replace(/\D/g,'').slice(0,11);
    if(v.length>=7)v=v.replace(/^(\d{2})(\d{5})(\d{0,4}).*/,'($1) $2-$3');
    else if(v.length>=3)v=v.replace(/^(\d{2})(\d{0,5})/,'($1) $2');
    e.target.value=v;
  });
  document.getElementById('send').onclick=submitCapture;
}

function submitCapture(){
  const name=document.getElementById('iName').value.trim();
  const wpp=document.getElementById('iWpp').value.replace(/\D/g,'');
  let ok=true;
  document.getElementById('fName').classList.toggle('error', name.length<2); if(name.length<2)ok=false;
  document.getElementById('fWpp').classList.toggle('error', wpp.length<10); if(wpp.length<10)ok=false;
  if(!ok)return;
  answers.name=name; answers.whatsapp=wpp;
  saveState();
  sendEvent('lead');
  next();
}

