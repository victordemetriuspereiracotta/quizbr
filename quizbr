function goCheckout(){
  sendEvent('checkout_click');
  window.location.href=buildCheckoutUrl(CONFIG.checkoutUrl);
}

function animateProjection(){
  const path=document.getElementById('projPath'); if(!path)return;
  const len=path.getTotalLength();
  path.style.strokeDasharray=len; path.style.strokeDashoffset=len;
  requestAnimationFrame(()=>{
    path.style.transition='stroke-dashoffset 1.8s cubic-bezier(.4,0,.2,1)';
    path.style.strokeDashoffset=0;
  });
  setTimeout(()=>{
    const area=document.getElementById('projArea');
    area.style.transition='opacity .8s'; area.style.opacity=.10;
    const d=document.getElementById('projDot'); d.style.transition='opacity .3s'; d.style.opacity=1;
    const d2=document.getElementById('projDot2'); d2.style.transition='opacity .3s'; d2.style.opacity=.2;
    const l=document.getElementById('projLbl'); l.style.transition='opacity .4s'; l.style.opacity=1;
  },1750);
}

/* ---------------- CHECKOUT URL (dados + UTMs) ---------------- */
function buildCheckoutUrl(base){
  try{
    const u = new URL(base);
    if(answers.name)     u.searchParams.set(CONFIG.checkoutParamName,  answers.name);
    if(answers.email)    u.searchParams.set(CONFIG.checkoutParamEmail, answers.email);
    if(answers.whatsapp) u.searchParams.set(CONFIG.checkoutParamPhone, "55"+answers.whatsapp);
    if(answers.utm){ for(const k in answers.utm){ u.searchParams.set(k, answers.utm[k]); } }
    return u.toString();
  }catch(e){ return base; }
}

/* ---------------- TIMER (persistido) ---------------- */
function startTimer(){
  const el=document.getElementById('timer'); if(!el)return;
  let deadline = parseInt(localStorage.getItem(LS_DEADLINE)||"0",10);
  if(!deadline || deadline < Date.now()-24*3600*1000){ deadline = Date.now()+15*60*1000; try{localStorage.setItem(LS_DEADLINE,deadline);}catch(e){} }
  const t=setInterval(()=>{
    const s=Math.floor((deadline-Date.now())/1000);
    if(s<=0){
      clearInterval(t);
      el.textContent="00:00";
      el.parentElement.querySelector('p').innerHTML="Seu tempo de reserva acabou — mas a condição de hoje ainda está de pé <b>somente até a meia-noite</b>.";
      maybeExit();
      return;
    }
    const m=String(Math.floor(s/60)).padStart(2,'0'), c=String(s%60).padStart(2,'0');
    el.textContent=`${m}:${c}`;
  },1000);
}

/* ---------------- STICKY CTA ---------------- */
function setupSticky(){
  const sc=document.getElementById('stickyCta');
  const onScroll=()=>{ sc.classList.toggle('show', window.scrollY>520 && FLOW[idx]==="result"); };
  window.addEventListener('scroll',onScroll,{passive:true});
  onScroll();
}

/* ---------------- EXIT INTENT / DOWNSELL ---------------- */
function maybeExit(){
  if(!CONFIG.downsellUrl) return;
  if(sessionStorage.getItem(LS_EXIT)) return;
  sessionStorage.setItem(LS_EXIT,"1");
  document.getElementById('modalOv').classList.add('show');
  sendEvent('exit_modal_view');
}
function setupExitIntent(nome){
  if(!CONFIG.downsellUrl) return;
  document.getElementById('mTitle').textContent = `${nome}, antes de sair…`;
  // Desktop: mouse saindo pelo topo
  document.addEventListener('mouseout',e=>{
    if(!e.relatedTarget && e.clientY<=0) maybeExit();
  });
  // Mobile: tentativa de voltar
  try{
    history.pushState({q:1},"");
    window.addEventListener('popstate',()=>{
      if(FLOW[idx]==="result" && !sessionStorage.getItem(LS_EXIT)){ maybeExit(); history.pushState({q:1},""); }
    });
  }catch(e){}
  document.getElementById('mDown').onclick=()=>{
    sendEvent('downsell_click');
    window.location.href=buildCheckoutUrl(CONFIG.downsellUrl);
  };
  document.getElementById('mStay').onclick=()=>{
    document.getElementById('modalOv').classList.remove('show');
    const ob=document.getElementById('offerBox'); if(ob) ob.scrollIntoView({behavior:'smooth',block:'start'});
  };
}

